# BAPP — Blacklist Alliance Proposal Publisher
# Copy to .env.local for local dev. Set all of these in Vercel project settings.

# API key used by the BAPP CoWork plugin to authenticate publish/delete requests
BL_PUBLISH_API_KEY=bl_pub_your_key_here

# Admin dashboard credentials (HTTP Basic Auth)
ADMIN_USER=blacklist
ADMIN_PASS=Blacklist2026!

# GitHub — used to commit published HTML files to this repo
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=Plura-AI
GITHUB_REPO=blacklist-published
